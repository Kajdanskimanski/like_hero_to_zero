@@ -0,0 +1,41 @@
+package org.example.like_hero_to_zero.controller;
+
+import org.example.like_hero_to_zero.domain.CO2Emission;
+import org.example.like_hero_to_zero.service.CO2Service;
+import org.springframework.stereotype.Controller;
+import org.springframework.ui.Model;
+import org.springframework.web.bind.annotation.GetMapping;
+import org.springframework.web.bind.annotation.RequestParam;
+
+import java.util.Optional;
+
+@Controller
+public class PublicController {
+
+    private final CO2Service co2Service;
+
+    public PublicController(CO2Service co2Service) {
+        this.co2Service = co2Service;
+    }
+
+    // GET /   → zeigt Suchseite
+    @GetMapping("/")
+    public String index() {
+        return "public"; // lädt public.html
+    }
+
+    // GET /search?country=Germany
+    @GetMapping("/search")
+    public String search(@RequestParam String country, Model model) {
+        Optional<CO2Emission> emission = co2Service.getLatestEmissionForCountry(country);
+
+        if (emission.isPresent()) {
+            model.addAttribute("emission", emission.get());
+        } else {
+            model.addAttribute("error", "Keine Daten für dieses Land gefunden.");
+        }
+
+        model.addAttribute("country", country);
+        return "public";
+    }
+}
