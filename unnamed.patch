@@ -0,0 +1,33 @@
+package org.example.like_hero_to_zero.service;
+
+import org.example.like_hero_to_zero.domain.CO2Emission;
+import org.example.like_hero_to_zero.repository.CO2EmissionRepository;
+import org.springframework.stereotype.Service;
+
+import java.util.List;
+import java.util.Optional;
+
+@Service
+public class CO2Service {
+
+    private final CO2EmissionRepository repository;
+
+    public CO2Service(CO2EmissionRepository repository) {
+        this.repository = repository;
+    }
+
+    // ✔ MUST-Anforderung: aktuellster Wert eines Landes
+    public Optional<CO2Emission> getLatestEmissionForCountry(String country) {
+        return repository.findTopByCountryOrderByYearDesc(country);
+    }
+
+    // Daten speichern (für Wissenschaftler:innen im Backend)
+    public CO2Emission save(CO2Emission emission) {
+        return repository.save(emission);
+    }
+
+    // Alle Datensätze anzeigen (optional)
+    public List<CO2Emission> findAll() {
+        return repository.findAll();
+    }
+}
